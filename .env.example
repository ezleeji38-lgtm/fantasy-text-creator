# ── Provider 선택 (anthropic / gemini / ollama) ──
# 키가 있는 provider를 자동 감지합니다. 명시적으로 지정하려면:
# NOVELCRAFT_PROVIDER=gemini

# ── Anthropic (유료) ──
# ANTHROPIC_API_KEY=sk-ant-...
# NOVELCRAFT_MODEL=claude-opus-4-6

# ── Google Gemini (무료) ── ⭐ 추천
# 무료 키 발급: https://aistudio.google.com/apikey
GOOGLE_API_KEY=your-gemini-api-key-here
NOVELCRAFT_MODEL=gemini-2.5-flash

# ── Ollama (로컬, 무료) ──
# OLLAMA_URL=http://localhost:11434
# NOVELCRAFT_MODEL=qwen2.5:14b
